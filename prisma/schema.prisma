// ═══════════════════════════════════════════════════════
// INTIMERA — Database Schema
// Design: Velvet Sanctuary
// Engine: PostgreSQL (Neon) via Prisma ORM
// ═══════════════════════════════════════════════════════

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ─────────────────────────────────────────────────────
// AUTH (Better Auth compatible tables)
// ─────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          Role      @default(USER)
  locale        String    @default("en")
  stripeCustomerId String? @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  sessions      Session[]
  accounts      Account[]
  coupleMembers CoupleMember[]
  progress      Progress[]
  bookmarks     Bookmark[]
  checkIns      CheckIn[]
  aiConversations AiConversation[]
  communityPosts  CommunityPost[]
  communityReplies CommunityReply[]
  votes         Vote[]
  subscription  Subscription?
  exerciseCompletions ExerciseCompletion[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

enum Role {
  USER
  PREMIUM
  COUPLES
  ADMIN
  CONTENT_MANAGER
}

// ─────────────────────────────────────────────────────
// COUPLES
// ─────────────────────────────────────────────────────

model Couple {
  id          String   @id @default(cuid())
  inviteCode  String   @unique @default(cuid())
  inviteExpiresAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members     CoupleMember[]
  sharedNotes SharedNote[]
  checkIns    CheckIn[]

  @@map("couple")
}

model CoupleMember {
  id        String   @id @default(cuid())
  userId    String
  coupleId  String
  role      CoupleRole @default(MEMBER)
  joinedAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple Couple @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@unique([userId, coupleId])
  @@map("couple_member")
}

model SharedNote {
  id              String   @id @default(cuid())
  coupleId        String
  encryptedContent String  // AES-256-GCM encrypted
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  couple Couple @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@map("shared_note")
}

enum CoupleRole {
  INITIATOR
  MEMBER
}

// ─────────────────────────────────────────────────────
// CONTENT (Articles, Guides, Educational Material)
// ─────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  icon        String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  content Content[]

  @@map("category")
}

model Content {
  id              String        @id @default(cuid())
  slug            String        @unique
  categoryId      String
  tier            SubscriptionTier @default(FREE)
  status          ContentStatus @default(DRAFT)
  difficulty      Difficulty    @default(BEGINNER)
  relationshipStage RelationshipStage @default(ANY)
  readingTimeMin  Int           @default(5)
  sortOrder       Int           @default(0)
  coverImage      String?
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  category     Category            @relation(fields: [categoryId], references: [id])
  translations ContentTranslation[]
  bookmarks    Bookmark[]
  progress     Progress[]

  @@index([categoryId])
  @@index([status, tier])
  @@index([slug])
  @@map("content")
}

model ContentTranslation {
  id        String @id @default(cuid())
  contentId String
  locale    String
  title     String
  summary   String
  body      String // Markdown content
  embedding Unsupported("vector(1536)")? // pgvector OpenAI embeddings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  // Note: HNSW index must be created via raw SQL: 
  // CREATE INDEX content_embedding_idx ON content_translation USING hnsw (embedding vector_l2_ops);

  @@unique([contentId, locale])
  @@map("content_translation")
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  PENDING
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum RelationshipStage {
  ANY
  DATING
  ENGAGED
  NEWLYWED
  ESTABLISHED
  RECONNECTING
}

// ─────────────────────────────────────────────────────
// EXERCISES (Interactive Activities)
// ─────────────────────────────────────────────────────

model Exercise {
  id              String       @id @default(cuid())
  slug            String       @unique
  type            ExerciseType
  tier            SubscriptionTier @default(FREE)
  difficulty      Difficulty   @default(BEGINNER)
  relationshipStage RelationshipStage @default(ANY)
  estimatedTimeMin Int         @default(10)
  title           String?
  description     String?
  coverImage      String?
  status          ContentStatus @default(DRAFT)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations (titles are in steps)
  steps       ExerciseStep[]
  completions ExerciseCompletion[]

  @@map("exercise")
}

model ExerciseStep {
  id         String   @id @default(cuid())
  exerciseId String
  stepNumber Int
  locale     String   @default("en")
  title      String
  instruction String
  type       StepType
  options    String?  // JSON array for multiple choice options
  createdAt  DateTime @default(now())

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([exerciseId, stepNumber, locale])
  @@map("exercise_step")
}

model ExerciseCompletion {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  responses  String   // JSON — encrypted
  score      Int?
  completedAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@map("exercise_completion")
}

enum ExerciseType {
  COUPLE
  INDIVIDUAL
  QUIZ
}

enum StepType {
  TEXT_PROMPT
  TEXT_INPUT
  MULTIPLE_CHOICE
  SCALE_SLIDER
  REFLECTION
}

// ─────────────────────────────────────────────────────
// USER PROGRESS & TRACKING
// ─────────────────────────────────────────────────────

model Progress {
  id          String   @id @default(cuid())
  userId      String
  contentId   String
  percentage  Int      @default(0) // 0-100
  completedAt DateTime?
  lastReadAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@map("progress")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@map("bookmark")
}

model CheckIn {
  id                String   @id @default(cuid())
  userId            String
  coupleId          String?
  moodScore         Int      // 1-5
  connectionScore   Int      // 1-5
  encryptedNotes    String?  // AES-256-GCM encrypted
  createdAt         DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple Couple? @relation(fields: [coupleId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("check_in")
}

// ─────────────────────────────────────────────────────
// AI CONVERSATIONS
// ─────────────────────────────────────────────────────

model AiConversation {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@index([userId, createdAt])
  @@map("ai_conversation")
}

model AiMessage {
  id               String   @id @default(cuid())
  conversationId   String
  role             MessageRole
  encryptedContent String   // AES-256-GCM encrypted
  createdAt        DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("ai_message")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ─────────────────────────────────────────────────────
// COMMUNITY (Anonymous Forum)
// ─────────────────────────────────────────────────────

model CommunityTopic {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  posts CommunityPost[]

  @@map("community_topic")
}

model CommunityPost {
  id          String           @id @default(cuid())
  topicId     String
  authorId    String
  title       String
  body        String
  isAnonymous Boolean          @default(true)
  status      ModerationStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  topic   CommunityTopic   @relation(fields: [topicId], references: [id])
  author  User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies CommunityReply[]
  votes   Vote[]

  @@index([topicId, createdAt])
  @@index([status])
  @@map("community_post")
}

model CommunityReply {
  id          String           @id @default(cuid())
  postId      String
  authorId    String
  parentId    String?          // For nested replies
  body        String
  isAnonymous Boolean          @default(true)
  status      ModerationStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  post   CommunityPost   @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent CommunityReply? @relation("ReplyTree", fields: [parentId], references: [id])
  children CommunityReply[] @relation("ReplyTree")
  votes  Vote[]

  @@index([postId, createdAt])
  @@map("community_reply")
}

model Vote {
  id       String   @id @default(cuid())
  userId   String
  postId   String?
  replyId  String?
  value    Int      // +1 or -1
  createdAt DateTime @default(now())

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  post  CommunityPost?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  reply CommunityReply? @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, replyId])
  @@map("vote")
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────────────
// SUBSCRIPTIONS (Stripe)
// ─────────────────────────────────────────────────────

model Subscription {
  id                 String           @id @default(cuid())
  userId             String           @unique
  stripeCustomerId   String?          @unique
  stripeSubscriptionId String?        @unique
  stripePriceId      String?
  tier               SubscriptionTier @default(FREE)
  status             SubStatus        @default(ACTIVE)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscription")
}

enum SubscriptionTier {
  FREE
  PREMIUM
  COUPLES
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}
